<% layout("/layouts/boilerplate") %>

    <body>
        <div class="row mt-3">
            <div class="col-8 offset-2">
                <h3>Edit your Listing </h3>
                <form method="POST" action="/listings/<%=listing._id%>?_method=PUT">
                    <div class="mb-3">
                        <label for="title" class="form-lable">Title</label>

                        <input type="text" name="listing[title]" value="<%= listing.title %>"
                            class="form-control form-l" />

                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-lable form-l">Description</label>
                        <textarea name="listing[description]"
                            class="form-control form-l"> <%= listing.description %></textarea>

                    </div>


                    <div class="mb-3">
                        <label for="image" class="form-lable from-l">Image Link</label>
                        <input type="text" name="listing[image]" value="<%= listing.image %>"
                            class="form-control form-l" />

                    </div>

                    <div class="row">
                        <div class="mb-3 col-md-4">
                            <label for="price" class="form-lable from-l">Price</label>
                            <input type="number" name="listing[price]" value="<%= listing.price%>"
                                class="form-control form-l" />
                        </div>

                        <div class="mb-3 col-md-8">
                                <label for="country" class="form-lable from-l">Country</label>
                                <input type="text" name="listing[country]" value="<%= listing.country%>"
                                    class="form-control form-l" />
                         </div>

                    </div>





                    <div class="mb-3">
                        <label for="location" class="form-lable from-l">Location</label>
                        <input type="text" name="listing[location]" value="<%= listing.location %>"
                            class="form-control form-l" />
                    </div>

                    <button class="btn btn-dark edit-btn from-l mt-3">Edit</button>
                    <br><br>
                </form>
            </div>
        </div>
    </body>