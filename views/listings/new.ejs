<% layout("/layouts/boilerplate") %>

    <body>
        <div class="row mt-3">
            <div class="col-8 offset-2 new-form">
                <h3 >Create a New Listing </h3>
                <form method="POST" action="/listings">
                    <div class="mb-3">
                        <label for="title" class="form-lable">Title</label>
                        <input type="text" name="listing[title]" placeholder="enter title" class="form-control">
                    </div>


                    <div class="mb-3">
                        <label for="description" class="form-lable form-l">Description</label>
                        <textarea name="listing[description]" placeholder="enter description"
                            class="form-control form-l "></textarea>

                    </div>

                    <div class="mb-3">
                        <label for="image" class="form-lable from-l">Image Link</label>
                        <input type="text" name="listing[image]" placeholder="enter image URL" class="form-control from-l">
                    </div>

                    <div class="row">

                        <div class="mb-3 col-md-4" >
                            <label for="price" class="form-lable from-l">Price</label>
                            <input type="number" name="listing[price]" placeholder="enter price" class="form-control from-l">
                        </div>

                        <div class="mb-3 col-md-8">
                            <label for="country" class="form-lable from-l">Country</label>
                            <input type="text" name="listing[country]" placeholder="enter country" class="form-control from-l">
                        </div>

                    </div>



                    <div class="mb-3">
                        <label for="location" class="form-lable from-l">Location</label>
                        <input type="text" name="listing[location]" placeholder="enter location" class="form-control from-l">
                    </div>
                    <button class="btn btn-dark add-btn from-l edit-btn mt-3">Add</button>
                </form>
            </div>
        </div>
    </body>